# Backend Configuration
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=False

# Frontend CORS Configuration
FRONTEND_URL=http://localhost:3000

# Model Configuration
MODEL_PATH=../models/cnn-parameters-improvement-23-0.91.model
MODEL_TYPE=h5

# File Upload Configuration
MAX_FILE_SIZE_MB=10
# Include common image extensions (JFIF is a JPEG variant)
ALLOWED_EXTENSIONS=jpg,jpeg,png,jfif,gif,bmp,webp,tiff,tif

# Image Processing
IMAGE_SIZE=150
NORMALIZE_IMAGES=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Environment
ENV=development
